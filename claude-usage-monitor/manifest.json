{
  "manifest_version": 3,
  "name": "Claude Usage Monitor",
  "version": "1.0.1",
  "description": "Claude 사용량을 배지에서 확인하고 한도 도달 전에 알림을 받습니다.",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Claude Usage Monitor",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "parser.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
